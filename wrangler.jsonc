{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bk",
  "compatibility_date": "2026-05-29",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "AESTHETE_DB",
      "id": "aesthete_db_kv"
    }
  ]
}
